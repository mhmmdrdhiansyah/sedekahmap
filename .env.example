# Database - sesuaikan dengan konfigurasi lokal
DATABASE_URL="postgresql://postgres:root@localhost:5432/sedekahmap"

# Auth.js (NextAuth v5) - generate dengan: openssl rand -base64 33
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# App URL - untuk link email verifikasi dan reset password
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email Service (opsional untuk development)
# Jika tidak diset, email akan di-log ke console saja
RESEND_API_KEY=""
EMAIL_FROM="noreply@sedekahmap.id"
